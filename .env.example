# ============================
# KOKO PROJECT - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual values
# ============================

# Google Gemini API Key (REPLACE with your REAL key)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Telegram Bot Token (REPLACE with your REAL token)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Local LLM Settings
LOCAL_LLM_BASE=http://localhost:8080/v1
LOCAL_LLM_API_KEY=local
LOCAL_LLM_MODEL=qwen-35b-local

# Coder Settings
CODER_LLM_BASE=http://localhost:8081/v1
CODER_LLM_API_KEY=local
CODER_LLM_MODEL=glm-4-flash
